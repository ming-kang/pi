# Default to LF for text files across the repo
* text=auto eol=lf

# Windows scripts should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should keep LF
*.sh text eol=lf

# Binary images and documents
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.bmp binary
*.tif binary
*.tiff binary
*.avif binary
*.ico binary
*.pdf binary

# Native modules, WebAssembly, fonts, archives, and databases
*.node binary
*.wasm binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.7z binary
*.tar binary
*.tgz binary
*.gz binary
*.bz2 binary
*.xz binary
*.db binary
*.sqlite binary
*.sqlite3 binary
